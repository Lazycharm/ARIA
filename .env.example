# ═══════════════════════════════════════════════════════════════
# ARIA — Autonomous Research & Intelligent Allocation
# ═══════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── MT5 Demo Account ──────────────────────────────────────────────
# Get a free demo from: ICMarkets, XM, Pepperstone, FP Markets
MT5_LOGIN=12345678
MT5_PASSWORD=your_demo_password
MT5_SERVER=ICMarketsSC-Demo
# Leave empty to use real-time MT5 data (recommended)
MT5_ENABLED=true

# ── Capital Settings ─────────────────────────────────────────────
ACCOUNT_BALANCE=1000.0          # Your actual balance (synced from MT5)
RISK_PER_TRADE_PCT=1.0          # 1% risk per trade
DAILY_TARGET_PCT=5.0            # 5% daily profit target
MAX_DAILY_LOSS_PCT=3.0          # 3% max daily drawdown
MAX_CONCURRENT_TRADES=3
MAX_TRADES_PER_DAY=5
EMERGENCY_DRAWDOWN_PCT=5.0      # Hard stop: close everything

# ── Strategy ──────────────────────────────────────────────────────
STRATEGY=hybrid_smc             # hybrid_smc | trend_ema | smc_only
HTF_BIAS_TF=H4                  # Timeframe for bias (H4, D1)
ENTRY_TF=M15                    # Timeframe for entry confirmation
EXEC_TF=M5                      # Execution timeframe

# ── Pairs ────────────────────────────────────────────────────────
WATCHLIST=EURUSD,GBPUSD,USDJPY,XAUUSD,GBPJPY,NAS100,AUDUSD

# ── Sessions (UTC) ────────────────────────────────────────────────
ASIAN_START=0
ASIAN_END=7
LONDON_START=7
LONDON_END=16
NY_START=12
NY_END=21
ACTIVE_SESSIONS=asian,london,ny

# ── Signal Filters ────────────────────────────────────────────────
MAX_SPREAD_PIPS=2.5             # Skip if spread above this
NEWS_BUFFER_MINUTES=20          # Don't trade 20min before major news
MIN_SIGNAL_SCORE=65             # 0-100, minimum confluence score to trade

# ── AI Models (cost-optimised: ~$1.60/month total) ───────────────
# Fable 5 is NOT auto-scheduled — only fires on manual deep analysis
MODEL_BRIEF=claude-haiku-4-5-20251001              # cheap commentary
MODEL_SESSION_ANALYSIS=claude-haiku-4-5-20251001   # pre-session levels
MODEL_DAILY_REPORT=claude-sonnet-4-6               # once/day end-of-day report
MODEL_DEEP_ANALYSIS=claude-fable-5                 # manual trigger only

# ── Obsidian Vault (shared brain) ────────────────────────────────
OBSIDIAN_VAULT_PATH=D:/A office/AyoubOS/02-Obsidian-Vault
OBSIDIAN_ARIA_FOLDER=03 Projects/ARIA

# ── Dashboard ────────────────────────────────────────────────────
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8050
SIGNAL_REFRESH_SECONDS=5        # Dashboard refresh rate

# ── Database ──────────────────────────────────────────────────────
DB_PATH=./db/aria.db

# ── News Calendar ─────────────────────────────────────────────────
# ForexFactory calendar (no API key needed, scraped)
NEWS_FILTER_ENABLED=true
NEWS_IMPACT_LEVEL=high          # high | medium | all

# ── Notifications (optional) ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Dry Run ───────────────────────────────────────────────────────
DRY_RUN=false                   # true = analyze only, no execution
LOG_LEVEL=INFO
